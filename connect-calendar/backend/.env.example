DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/connect_calendar

FIREBASE_PROJECT_ID=elimulink-connect
GOOGLE_APPLICATION_CREDENTIALS=C:\Secrets\elimulink-connect-firebase-admin.json
FIREBASE_SERVICE_ACCOUNT_JSON=
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
USER_PROFILES_TABLE=user_profiles
LOCAL_DEV_AUTH_BYPASS=false
LOCAL_DEV_AUTH_UID=local-calendar-dev
LOCAL_DEV_AUTH_EMAIL=calendar-dev@localhost

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175,https://calendar.elimulink.co.ke,https://elimulink-connect-calendar.web.app,https://elimulink-connect-calendar.firebaseapp.com
CORS_ORIGIN_REGEX=^https://([a-z0-9-]+\.)?elimulink\.co\.ke$
