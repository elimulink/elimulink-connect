# Allow your frontend
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,https://meet.elimulink.co.ke,https://elimulink-connect-meet.web.app,https://elimulink-connect-meet.firebaseapp.com
CORS_ORIGIN_REGEX=^https://([a-z0-9-]+\.)?elimulink\.co\.ke$

# Firebase Admin (path to your service account json)
GOOGLE_APPLICATION_CREDENTIALS=C:\Secrets\elimulink-connect-firebase-admin.json

# Optional: enforce project id match
FIREBASE_PROJECT_ID=elimulink-connect

# Supabase authorization source
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
USER_PROFILES_TABLE=user_profiles

# Realtime signaling discipline
MEET_REALTIME_MODE=single-instance
MEET_ALLOW_LOCAL_DEV_BYPASS=false
MEET_RECONNECT_GRACE_SECONDS=30
MEET_SIGNALING_MAX_MESSAGE_BYTES=131072
MEET_SIGNALING_MAX_CHAT_CHARS=4000
MEET_SIGNALING_MAX_ATTACHMENTS=10
MEET_ATTACHMENT_URL_TTL_SECONDS=1800

# ICE/TURN evolution seam
MEET_ICE_SERVER_URLS=stun:stun.l.google.com:19302
MEET_ICE_SERVER_USERNAME=
MEET_ICE_SERVER_CREDENTIAL=

# Deployment hint
WEB_CONCURRENCY=1
